# MT5 账户登录信息
MT5_LOGIN=12345678
MT5_PASSWORD=your_investor_password
MT5_SERVER=ICMarketsSC-MT5-6

# 可选：terminal64.exe 绝对路径
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# 可选：同一券商的候选服务器别名，逗号分隔
# MT5_SERVER_ALIASES=ICMarketsSC-MT5,ICMarketsSC-MT5-5

# 推荐：填写 MT5 / 券商服务器真实时区，把历史成交/持仓/挂单时间统一归一化到 UTC
# 对 ICMarketsSC-MT5-6 这类 GMT+2 / GMT+3（夏令时）服务器，推荐使用 Europe/Athens
MT5_SERVER_TIMEZONE=Europe/Athens

# 兼容旧链路：仅当你明确只想按固定分钟差处理时再填写
MT5_TIME_OFFSET_MINUTES=0

# 可选：初始化/登录超时（毫秒）
MT5_INIT_TIMEOUT_MS=90000

# 建议只监听本机，再由 Caddy/Nginx 对外统一转发
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# 轻量管理面板只监听本机，由 Caddy 统一通过 /admin/ 对外转发
ADMIN_PANEL_HOST=127.0.0.1
ADMIN_PANEL_PORT=8788
ADMIN_GATEWAY_URL=http://127.0.0.1:8787
ADMIN_GATEWAY_TASK_NAME=MT5GatewayAutoStart

# 可选：若 Caddy / Nginx / MT5 客户端需要自定义控制方式，可填服务名或命令
# ADMIN_CADDY_SERVICE_NAME=Caddy
# ADMIN_NGINX_SERVICE_NAME=nginx
# ADMIN_MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# ADMIN_CADDY_START_CMD=
# ADMIN_CADDY_STOP_CMD=
# ADMIN_CADDY_RESTART_CMD=
# ADMIN_NGINX_START_CMD=
# ADMIN_NGINX_STOP_CMD=
# ADMIN_NGINX_RESTART_CMD=
# ADMIN_MT5_START_CMD=
# ADMIN_MT5_STOP_CMD=
# ADMIN_MT5_RESTART_CMD=

# auto：优先 EA 推送，拿不到新鲜数据时回退到 Python 直连
# pull：始终使用 MetaTrader5 Python 直连
# ea：只接受 EA 推送
GATEWAY_MODE=auto
EA_SNAPSHOT_TTL_SEC=20
SNAPSHOT_BUILD_CACHE_MS=8000
SNAPSHOT_DELTA_ENABLED=1
SNAPSHOT_DELTA_FALLBACK_RATIO=0.85

# 可选：给 /v1/ea/snapshot 增加鉴权
# EA_INGEST_TOKEN=change_me
